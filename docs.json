{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Opaque Protocol",
  "description": "Stealth payments, provable reputation, and cross-chain announcements.",
  "colors": {
    "primary": "#5eead4",
    "light": "#5eead4",
    "dark": "#2dd4bf"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://www.opaque.cash"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "fonts": {
    "heading": {
      "family": "Syne",
      "weight": 700
    },
    "body": {
      "family": "DM Sans",
      "weight": 400
    }
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#f8fafc",
      "dark": "#07080d"
    }
  },
  "styling": {
    "codeblocks": "dark"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/opaquecash/sdk"
      },
      {
        "label": "npm",
        "href": "https://www.npmjs.com/package/@opaquecash/opaque"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get started",
      "href": "/quickstart"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "quickstart",
              "sdk/installation"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/stealth-payments",
              "concepts/psr",
              "concepts/cross-chain"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/register-and-receive",
              "guides/send-stealth-payment",
              "guides/create-schema",
              "guides/issue-attestation",
              "guides/scan-and-sweep",
              "guides/generate-proof",
              "guides/ons-naming"
            ]
          },
          {
            "group": "SDK reference",
            "pages": [
              "sdk/opaque-client",
              "sdk/stealth-api",
              "sdk/psr-api",
              "sdk/reputation-api",
              "sdk/cross-chain-api",
              "sdk/react",
              "sdk/utilities",
              "sdk/relayer-client"
            ]
          },
          {
            "group": "Protocol",
            "pages": [
              "protocol/overview",
              "protocol/deployments"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Protocol spec",
          "href": "https://github.com/opaquecash/spec",
          "icon": "book"
        },
        {
          "anchor": "App",
          "href": "https://www.opaque.cash",
          "icon": "globe"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/opaquecash"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ]
  }
}
